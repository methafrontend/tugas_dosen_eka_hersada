    "@angular/platform-browser": "^19.1.0",
    "@angular/platform-browser-dynamic": "^19.1.0",
    "@angular/router": "^19.1.0",
    "@ngx-pwa/local-storage": "19.0.0",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/postcss": "^4.3.2",
    "postcss": "^8.5.19",
    "primeicons": "^7.0.0",
